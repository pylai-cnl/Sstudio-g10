{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "isStudent": { "type": "boolean" },
        "dormLocation": { "type": "string" },
        "salesCount": { "type": "number" },
        "purchasesCount": { "type": "number" },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "cart": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "description": "A conversation between two users about a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "productId": { "type": "string" },
        "productTitle": { "type": "string" },
        "productImage": { "type": "string" },
        "unreadBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["participants", "productId"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Second-hand item listed for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "condition": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerAvatar": { "type": "string" },
        "sellerIsStudent": { "type": "boolean" },
        "dormLocation": { "type": "string" },
        "departureDate": { "type": "string", "format": "date" },
        "referenceLink": { "type": "string" },
        "status": { "type": "string", "enum": ["Still on", "Sold"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category", "sellerId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Chat rooms"
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a chat room"
    }
  }
}
